NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://tertip:password@localhost:5432/tertip
# true | false — external VPS DB usually false; set true if server requires TLS
DATABASE_SSL=false

JWT_USER_SECRET=change-this-user-secret-in-production
JWT_ADMIN_SECRET=change-this-admin-secret-in-production
JWT_USER_ACCESS_EXPIRES_IN=15m
JWT_ADMIN_ACCESS_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_DAYS=30
STREAM_GATEWAY_EXPIRES_IN=60s

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/user/google/callback
FRONTEND_URL=http://localhost:5173
