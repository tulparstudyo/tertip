{
  "info": {
    "_postman_id": "tertip-api-v1",
    "name": "Tertip API",
    "description": "Tertip backend REST API collection.\n\nBase URL: {{baseUrl}}\n\nAfter Register or Login, `userAccessToken` and `refreshToken` are saved automatically.\nAfter Admin Login, `adminAccessToken` is saved automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "deviceId", "value": "postman-device-001" },
    { "key": "userAccessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "adminAccessToken", "value": "" },
    { "key": "sourceId", "value": "1" },
    { "key": "gatewayToken", "value": "" },
    { "key": "googleOAuthUrl", "value": "" },
    { "key": "projectId", "value": "1" }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept-Language', value: 'tr' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Veritabanı bağlantısını da test eder."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User — Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "    if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@tertip.com\",\n  \"password\": \"testpass123\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["user", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "    if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@tertip.com\",\n  \"password\": \"testpass123\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["user", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data?.accessToken) pm.collectionVariables.set('userAccessToken', json.data.accessToken);",
                  "    if (json.data?.refreshToken) pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"deviceId\": \"{{deviceId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["user", "auth", "refresh"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["user", "auth", "logout"]
            }
          },
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{userAccessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["user", "auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
